# ---- App ----
NODE_ENV=development
API_PORT=3001

# ---- Database (PostgreSQL + pgvector) ----
DATABASE_URL=postgresql://vibesphere:vibesphere@localhost:5432/vibesphere?schema=public

# ---- Redis (BullMQ) ----
REDIS_URL=redis://localhost:6379

# ---- Storage de documentos ----
# Diretorio compartilhado entre API (escrita no upload) e worker (leitura na ingestao).
# Use um caminho ABSOLUTO, pois api e worker rodam com working directories diferentes.
UPLOAD_DIR=/tmp/vibesphere-uploads

# ---- Auth ----
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ---- Secrets encryption (AES-256) ----
# 32-byte key, base64 or hex encoded
ENCRYPTION_KEY=change-me-32-byte-encryption-key!!

# ---- LLM Providers ----
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Opcionais (provedores alternativos)
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# ---- WhatsApp (Meta Cloud API) ----
# As credenciais do canal (phoneNumberId, accessToken, appSecret, verifyToken)
# sao informadas no cadastro do canal e armazenadas criptografadas.
# Webhook por canal: /api/webhooks/whatsapp/:channelId
WHATSAPP_VERIFY_TOKEN=change-me-verify-token

# ---- Billing (Stripe) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
